{
  "datasets": [
    {
      "name": "ds_kpis",
      "displayName": "KPIs",
      "queryLines": [
        "SELECT (SELECT SUM(energia_perdida_kWh_aprox) FROM serverless_stable_cvpomp_catalog.engie_peru_pdm.gold_derate_events) AS energia_no_generada_kWh, (SELECT valor FROM serverless_stable_cvpomp_catalog.engie_peru_pdm.gold_model_metrics WHERE metrica='roc_auc') AS roc_auc, (SELECT COUNT(DISTINCT turbine) FROM serverless_stable_cvpomp_catalog.engie_peru_pdm.gold_health_timeline) AS n_turbinas, (SELECT COUNT(*) FROM serverless_stable_cvpomp_catalog.engie_peru_pdm.gold_derate_events WHERE intervalos_derateo_10min > 0) AS dias_con_derateo"
      ]
    },
    {
      "name": "ds_health_daily",
      "displayName": "Health diario por turbina",
      "queryLines": [
        "SELECT turbine, DATE(ts) AS dia, AVG(health_index) AS health_index_avg FROM serverless_stable_cvpomp_catalog.engie_peru_pdm.gold_health_timeline GROUP BY turbine, DATE(ts)"
      ]
    },
    {
      "name": "ds_powerratio_daily",
      "displayName": "Power ratio diario (produciendo)",
      "queryLines": [
        "SELECT turbine, DATE(ts) AS dia, AVG(power_ratio) AS power_ratio_avg FROM serverless_stable_cvpomp_catalog.engie_peru_pdm.gold_health_timeline WHERE producing = 1 GROUP BY turbine, DATE(ts)"
      ]
    },
    {
      "name": "ds_energy_turbine",
      "displayName": "Energia no generada por turbina",
      "queryLines": [
        "SELECT turbine, SUM(energia_perdida_kWh_aprox) AS energia_perdida_kWh FROM serverless_stable_cvpomp_catalog.engie_peru_pdm.gold_derate_events GROUP BY turbine"
      ]
    },
    {
      "name": "ds_drivers",
      "displayName": "Top drivers de alerta",
      "queryLines": [
        "SELECT feature, importancia FROM serverless_stable_cvpomp_catalog.engie_peru_pdm.gold_alert_drivers ORDER BY importancia DESC LIMIT 12"
      ]
    },
    {
      "name": "ds_top_days",
      "displayName": "Top dias por energia perdida",
      "queryLines": [
        "SELECT CONCAT(turbine, ' | ', CAST(dia AS STRING)) AS turbina_dia, energia_perdida_kWh_aprox FROM serverless_stable_cvpomp_catalog.engie_peru_pdm.gold_derate_events ORDER BY energia_perdida_kWh_aprox DESC LIMIT 15"
      ]
    },
    {
      "name": "ds_alert_table",
      "displayName": "Alertas (alert_score > 0.6)",
      "queryLines": [
        "SELECT turbine, ts, health_index, alert_score, power_ratio FROM serverless_stable_cvpomp_catalog.engie_peru_pdm.gold_health_timeline WHERE alert_score > 0.6 ORDER BY ts DESC LIMIT 200"
      ]
    },
    {
      "name": "bb34131a",
      "displayName": "Energía Perdida por Mes",
      "queryLines": [
        "\n",
        "SELECT \n",
        "  DATE_TRUNC('month', CAST(SPLIT(`turbina_dia`, ' \\\\| ')[1] AS DATE)) as mes,\n",
        "  SUM(`energia_perdida_kWh_aprox`) as energia_perdida_total_kWh\n",
        "FROM `top_dias_por_energia_perdida_ds_top_days`\n",
        "GROUP BY DATE_TRUNC('month', CAST(SPLIT(`turbina_dia`, ' \\\\| ')[1] AS DATE))\n",
        "ORDER BY energia_perdida_total_kWh DESC\n"
      ]
    }
  ],
